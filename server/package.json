{
  "name": "diamond-heist-server",
  "version": "1.0.0",
  "description": "Diamond Heist: Mini Arenas – WebSocket game server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
