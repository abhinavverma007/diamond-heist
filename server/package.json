    "watch": "tsc --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
